<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Instagram</title>
    <link rel="stylesheet" href="/home.css">
  </head>
  <body>
  
<h1>Instagram</h1>
<a href="/posts/new" class="create-post">Create New Post</a>

<div class="posts-grid">
  <% for(let post of posts){ %>
    <div class="post">
      <a href="/posts/<%= post.username %>">
        @<%= post.username %>
      </a>

      <img
        src="<%= post.image %>"
        alt="post image"
      >

      <p><%= post.caption %></p>

      <a href="/posts/id/<%= post.id %>">
        View Post
      </a>
    </div>
  <% } %>
</div>

  </body>
</html>
