
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Single Post</title>

  <link rel="stylesheet" href="/post.css">
</head>
<body>

  <div class="post-container">

    <div class="post-header">
      <h2><%= post.username %></h2>
      <div class="post-id"><%= post.id %></div>
    </div>

    <img
      src="<%= post.image %>"
      alt="post image"
      class="post-image"
    >

    <div class="post-caption">
      <strong>Caption:</strong> <%= post.caption %>
    </div>

    <div class="actions">
      <a
        href="/posts/id/<%= post.id %>/edit"
        class="edit-btn"
      >
        Edit Post
      </a>

      <form
        method="POST"
        action="/posts/id/<%= post.id %>?_method=DELETE"
      >
        <button class="delete-btn">
          Delete
        </button>
      </form>
    </div>

  </div>

</body>
</html>